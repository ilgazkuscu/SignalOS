{
  "name": "signalos",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "cd apps/web && next dev",
    "build": "cd apps/web && next build",
    "start": "cd apps/web && next start",
    "lint": "eslint apps/web/src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark": "tsx scripts/benchmark.ts",
    "news:poll": "tsx scripts/poll-news.ts",
    "news:loop": "tsx scripts/poll-news-loop.ts",
    "architecture:check": "node scripts/check-module-boundaries.mjs",
    "maint:check": "npm run architecture:check && npm run lint && npm run typecheck && npm test",
    "validate": "npm run maint:check && npm run build",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "npm run db:generate",
    "prisma:migrate": "npm run db:migrate",
    "prisma:seed": "npm run seed"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "katex": "^0.16.45",
    "lucide-react": "^0.460.0",
    "next": "^15.0.3",
    "react": "^19.0.0-rc-66855b96-20241106",
    "react-dom": "^19.0.0-rc-66855b96-20241106",
    "react-katex": "^3.1.0",
    "recharts": "^2.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
